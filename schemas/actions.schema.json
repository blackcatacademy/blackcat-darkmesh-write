{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blackcat.academy/schemas/actions.schema.json",
  "title": "WriteActions",
  "type": "object",
  "properties": {
    "SaveDraftPage": {
      "type": "object",
      "required": ["siteId", "pageId", "locale", "blocks"],
      "properties": {
        "siteId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "pageId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "locale": { "type": "string", "minLength": 2, "maxLength": 10 },
        "blocks": { "type": "array" }
      },
      "additionalProperties": false
    },
    "PublishPageVersion": {
      "type": "object",
      "required": ["siteId", "pageId", "versionId", "manifestTx"],
      "properties": {
        "siteId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "pageId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "versionId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "manifestTx": { "type": "string", "minLength": 10 }
      },
      "additionalProperties": false
    },
    "UpsertRoute": {
      "type": "object",
      "required": ["siteId", "path", "target"],
      "properties": {
        "siteId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "path": { "type": "string", "pattern": "^/[^\\s]*$" },
        "target": { "type": "string" }
      },
      "additionalProperties": false
    },
    "UpsertProduct": {
      "type": "object",
      "required": ["siteId", "sku", "payload"],
      "properties": {
        "siteId": { "type": "string" },
        "sku": { "type": "string" },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },
    "AssignRole": {
      "type": "object",
      "required": ["actor", "subject", "role", "tenant"],
      "properties": {
        "actor": { "type": "string" },
        "subject": { "type": "string" },
        "role": { "type": "string" },
        "tenant": { "type": "string" }
      },
      "additionalProperties": false
    },
    "UpsertProfile": {
      "type": "object",
      "required": ["subject", "profile"],
      "properties": {
        "subject": { "type": "string" },
        "profile": { "type": "object" }
      },
      "additionalProperties": false
    },
    "GrantEntitlement": {
      "type": "object",
      "required": ["subject", "asset", "policy"],
      "properties": {
        "subject": { "type": "string" },
        "asset": { "type": "string" },
        "policy": { "type": "string" }
      },
      "additionalProperties": false
    },
    "RevokeEntitlement": {
      "type": "object",
      "required": ["subject", "asset"],
      "properties": {
        "subject": { "type": "string" },
        "asset": { "type": "string" }
      },
      "additionalProperties": false
    },
    "UpsertInventory": {
      "type": "object",
      "required": ["siteId", "sku", "quantity"],
      "properties": {
        "siteId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "sku": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "quantity": { "type": "integer", "minimum": 0 },
        "location": { "type": "string" }
      },
      "additionalProperties": false
    },
    "UpsertPriceRule": {
      "type": "object",
      "required": ["siteId", "ruleId", "formula"],
      "properties": {
        "siteId": { "type": "string" },
        "ruleId": { "type": "string" },
        "formula": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "GrantRole": {
      "type": "object",
      "required": ["tenant", "subject", "role"],
      "properties": {
        "tenant": { "type": "string" },
        "subject": { "type": "string" },
        "role": { "type": "string" }
      },
      "additionalProperties": false
    },
    "UpsertCustomer": {
      "type": "object",
      "required": ["tenant", "customerId", "profile"],
      "properties": {
        "tenant": { "type": "string" },
        "customerId": { "type": "string" },
        "profile": { "type": "object" }
      },
      "additionalProperties": false
    },
    "UpsertOrderStatus": {
      "type": "object",
      "required": ["orderId", "status"],
      "properties": {
        "orderId": { "type": "string" },
        "status": { "type": "string", "enum": ["created", "paid", "shipped", "delivered", "cancelled", "refunded"] },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "IssueRefund": {
      "type": "object",
      "required": ["orderId", "amount"],
      "properties": {
        "orderId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "amount": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "enum": ["USD", "EUR", "GBP", "CZK", "CHF", "JPY", "AUD", "CAD"] },
        "vatRate": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "CreateWebhook": {
      "type": "object",
      "required": ["tenant", "url", "events"],
      "properties": {
        "tenant": { "type": "string" },
        "url": { "type": "string" },
        "events": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      },
      "additionalProperties": false
    },
    "DeleteRoute": {
      "type": "object",
      "required": ["siteId", "path"],
      "properties": {
        "siteId": { "type": "string" },
        "path": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "description": "Action-specific payload schemas keyed by action name."
}
