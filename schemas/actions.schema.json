{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blackcat.academy/schemas/actions.schema.json",
  "title": "WriteActions",
  "type": "object",
  "properties": {
    "SaveDraftPage": {
      "type": "object",
      "required": ["siteId", "pageId", "locale", "blocks"],
      "properties": {
        "siteId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "pageId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "locale": { "type": "string", "minLength": 2, "maxLength": 10 },
        "blocks": { "type": "array" }
      },
      "additionalProperties": false
    },
    "ApplyCoupon": {
      "type": "object",
      "required": ["orderId", "code"],
      "properties": {
        "orderId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "code": { "type": "string", "minLength": 1, "maxLength": 64 }
      },
      "additionalProperties": false
    },
    "RemoveCoupon": {
      "type": "object",
      "required": ["orderId"],
      "properties": {
        "orderId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" }
      },
      "additionalProperties": false
    },
    "CartAddItem": {
      "type": "object",
      "required": ["cartId", "siteId", "sku", "qty", "price", "currency"],
      "properties": {
        "cartId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "siteId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "sku": { "type": "string" },
        "productId": { "type": "string" },
        "title": { "type": "string" },
        "qty": { "type": "integer", "minimum": 1 },
        "price": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
        "variant": { "type": "object" },
        "weight": { "type": "number", "minimum": 0 },
        "dimensions": { "type": "object" }
      },
      "additionalProperties": false
    },
    "CartRemoveItem": {
      "type": "object",
      "required": ["cartId", "sku"],
      "properties": {
        "cartId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "sku": { "type": "string" }
      },
      "additionalProperties": false
    },
    "AddShippingRate": {
      "type": "object",
      "required": ["siteId", "country", "price", "currency"],
      "properties": {
        "siteId": { "type": "string" },
        "country": { "type": "string", "minLength": 2, "maxLength": 2 },
        "region": { "type": "string" },
        "minWeight": { "type": "number", "minimum": 0 },
        "maxWeight": { "type": "number", "minimum": 0 },
        "price": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
        "carrier": { "type": "string" },
        "service": { "type": "string" }
      },
      "additionalProperties": false
    },
    "GetShippingQuote": {
      "type": "object",
      "required": ["cartId", "country"],
      "properties": {
        "cartId": { "type": "string" },
        "country": { "type": "string", "minLength": 2, "maxLength": 2 },
        "region": { "type": "string" }
      },
      "additionalProperties": false
    },
    "AddTaxRate": {
      "type": "object",
      "required": ["country", "rate"],
      "properties": {
        "country": { "type": "string", "minLength": 2, "maxLength": 2 },
        "region": { "type": "string" },
        "rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "category": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ValidateAddress": {
      "type": "object",
      "required": ["country"],
      "properties": {
        "country": { "type": "string", "minLength": 2, "maxLength": 2 },
        "region": { "type": "string" },
        "city": { "type": "string" },
        "postal": { "type": "string" },
        "line1": { "type": "string" },
        "line2": { "type": "string" }
      },
      "additionalProperties": false
    },
    "CreateOrder": {
      "type": "object",
      "required": ["cartId", "customerId", "siteId", "currency"],
      "properties": {
        "cartId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "customerId": { "type": "string" },
        "siteId": { "type": "string" },
        "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
        "shipping": { "type": "number", "minimum": 0 },
        "vatRate": { "type": "number", "minimum": 0 },
        "coupon": { "type": "string" },
        "address": { "type": "object" }
      },
      "additionalProperties": false
    },
    "PublishPageVersion": {
      "type": "object",
      "required": ["siteId", "pageId", "versionId", "manifestTx"],
      "properties": {
        "siteId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "pageId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "versionId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "manifestTx": { "type": "string", "minLength": 10 }
      },
      "additionalProperties": false
    },
    "UpsertRoute": {
      "type": "object",
      "required": ["siteId", "path", "target"],
      "properties": {
        "siteId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "path": { "type": "string", "pattern": "^/[^\\s]*$" },
        "target": { "type": "string" }
      },
      "additionalProperties": false
    },
    "UpsertProduct": {
      "type": "object",
      "required": ["siteId", "sku", "payload"],
      "properties": {
        "siteId": { "type": "string" },
        "sku": { "type": "string" },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },
    "AssignRole": {
      "type": "object",
      "required": ["actor", "subject", "role", "tenant"],
      "properties": {
        "actor": { "type": "string" },
        "subject": { "type": "string" },
        "role": { "type": "string" },
        "tenant": { "type": "string" }
      },
      "additionalProperties": false
    },
    "UpsertProfile": {
      "type": "object",
      "required": ["subject", "profile"],
      "properties": {
        "subject": { "type": "string" },
        "profile": { "type": "object" }
      },
      "additionalProperties": false
    },
    "GrantEntitlement": {
      "type": "object",
      "required": ["subject", "asset", "policy"],
      "properties": {
        "subject": { "type": "string" },
        "asset": { "type": "string" },
        "policy": { "type": "string" }
      },
      "additionalProperties": false
    },
    "RevokeEntitlement": {
      "type": "object",
      "required": ["subject", "asset"],
      "properties": {
        "subject": { "type": "string" },
        "asset": { "type": "string" }
      },
      "additionalProperties": false
    },
    "UpsertInventory": {
      "type": "object",
      "required": ["siteId", "sku", "quantity"],
      "properties": {
        "siteId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "sku": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "quantity": { "type": "integer", "minimum": 0 },
        "location": { "type": "string" }
      },
      "additionalProperties": false
    },
    "UpsertPriceRule": {
      "type": "object",
      "required": ["siteId", "ruleId", "formula"],
      "properties": {
        "siteId": { "type": "string" },
        "ruleId": { "type": "string" },
        "formula": { "type": "string" },
        "active": { "type": "boolean" },
        "currency": { "type": "string", "enum": ["USD", "EUR", "GBP", "CZK", "CHF", "JPY", "AUD", "CAD"] },
        "vatRate": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "GrantRole": {
      "type": "object",
      "required": ["tenant", "subject", "role"],
      "properties": {
        "tenant": { "type": "string" },
        "subject": { "type": "string" },
        "role": { "type": "string" }
      },
      "additionalProperties": false
    },
    "UpsertCustomer": {
      "type": "object",
      "required": ["tenant", "customerId", "profile"],
      "properties": {
        "tenant": { "type": "string" },
        "customerId": { "type": "string" },
        "profile": { "type": "object" }
      },
      "additionalProperties": false
    },
    "UpsertOrderStatus": {
      "type": "object",
      "required": ["orderId", "status"],
      "properties": {
        "orderId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "status": { "type": "string", "enum": ["created", "paid", "shipped", "delivered", "cancelled", "refunded"] },
        "reason": { "type": "string" },
        "totalAmount": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "enum": ["USD", "EUR", "GBP", "CZK", "CHF", "JPY", "AUD", "CAD"] },
        "vatRate": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "IssueRefund": {
      "type": "object",
      "required": ["orderId", "amount", "currency"],
      "properties": {
        "orderId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "amount": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "enum": ["USD", "EUR", "GBP", "CZK", "CHF", "JPY", "AUD", "CAD"] },
        "vatRate": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "CreatePaymentIntent": {
      "type": "object",
      "required": ["orderId", "amount", "currency"],
      "properties": {
        "orderId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "amount": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "enum": ["USD", "EUR", "GBP", "CZK", "CHF", "JPY", "AUD", "CAD"] },
        "provider": { "type": "string", "enum": ["gopay", "manual", "stripe", "paypal"], "default": "manual" },
        "returnUrl": { "type": "string" },
        "description": { "type": "string" },
        "providerMetadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "CapturePayment": {
      "type": "object",
      "required": ["paymentId"],
      "properties": {
        "paymentId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" }
      },
      "additionalProperties": false
    },
    "VoidPayment": {
      "type": "object",
      "required": ["paymentId"],
      "properties": {
        "paymentId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "UpsertShipmentStatus": {
      "type": "object",
      "required": ["shipmentId", "status", "orderId"],
      "properties": {
        "shipmentId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "status": { "type": "string", "enum": ["pending", "packed", "shipped", "delivered", "lost", "returned"] },
        "tracking": { "type": "string" },
        "carrier": { "type": "string" },
        "orderId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" }
      },
      "additionalProperties": false
    },
    "UpsertReturnStatus": {
      "type": "object",
      "required": ["returnId", "status", "orderId"],
      "properties": {
        "returnId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "status": { "type": "string", "enum": ["requested", "approved", "rejected", "received", "refunded", "closed"] },
        "reason": { "type": "string" },
        "orderId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" }
      },
      "additionalProperties": false
    },
    "CreateWebhook": {
      "type": "object",
      "required": ["tenant", "url", "events"],
      "properties": {
        "tenant": { "type": "string" },
        "url": { "type": "string" },
        "events": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      },
      "additionalProperties": false
    },
    "ProviderWebhook": {
      "type": "object",
      "required": ["provider", "paymentId", "status"],
      "properties": {
        "provider": { "type": "string", "enum": ["gopay"] },
        "paymentId": { "type": "string" },
        "status": { "type": "string" },
        "raw": { "type": "object" }
      },
      "additionalProperties": false
    },
    "DeleteRoute": {
      "type": "object",
      "required": ["siteId", "path"],
      "properties": {
        "siteId": { "type": "string" },
        "path": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "description": "Action-specific payload schemas keyed by action name."
}
